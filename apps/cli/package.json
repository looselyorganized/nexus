{
  "name": "nexus-eng",
  "version": "0.1.0",
  "description": "CLI for Nexus - multi-agent engineering coordination",
  "type": "module",
  "bin": {
    "nexus": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --minify",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": ["nexus", "cli", "multi-agent", "coordination", "engineering"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.0.0",
    "zod": "^3.24.1",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
